{
  "info": {
    "name": "Sahyog API v2.0 - Business Logic Fixes",
    "description": "Updated API collection with new validation and authorization requirements. Use this to test the backend changes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "SOS - Resolve with Proof (Volunteer)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{clerk_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"resolved\",\n  \"resolution_proof\": [\n    \"https://example.com/proof1.jpg\",\n    \"https://example.com/proof2.jpg\"\n  ],\n  \"resolution_notes\": \"Provided first aid and called ambulance\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/sos/{{sos_id}}/status",
          "host": ["{{base_url}}"],
          "path": ["sos", "{{sos_id}}", "status"]
        },
        "description": "Volunteer resolving SOS - MUST include resolution_proof"
      },
      "response": []
    },
    {
      "name": "SOS - Resolve without Proof (Coordinator Override)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{coordinator_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"resolved\",\n  \"resolution_notes\": \"Verified and resolved by coordinator\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/sos/{{sos_id}}/status",
          "host": ["{{base_url}}"],
          "path": ["sos", "{{sos_id}}", "status"]
        },
        "description": "Coordinator can resolve without proof (override)"
      },
      "response": []
    },
    {
      "name": "SOS - Resolve WITHOUT Proof (Should Fail)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{volunteer_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"resolved\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/sos/{{sos_id}}/status",
          "host": ["{{base_url}}"],
          "path": ["sos", "{{sos_id}}", "status"]
        },
        "description": "This should fail with 403 - proof required for volunteers"
      },
      "response": []
    },
